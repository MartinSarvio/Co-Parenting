generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Authentication ───────────────────────────────

model User {
  id                String    @id @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String
  avatar            String?
  color             String    @default("warm")
  phone             String?
  role              String    @default("parent")
  professionalType  String?   @map("professional_type")
  organization      String?
  isAdmin           Boolean   @default(false) @map("is_admin")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  householdMembers  HouseholdMember[]
  childrenAsParent1 Child[]           @relation("Parent1")
  childrenAsParent2 Child[]           @relation("Parent2")
  messagesSent      Message[]
  tasksCreated      Task[]            @relation("TaskCreator")
  tasksAssigned     Task[]            @relation("TaskAssignee")
  eventsCreated     CalendarEvent[]
  expensesPaid      Expense[]
  documents         Document[]
  photos            FamilyPhoto[]
  diaryEntries      DiaryEntry[]
  decisions         DecisionLog[]     @relation("DecisionProposer")
  deviceTokens      DeviceToken[]
  stripeSubscription StripeSubscription?

  @@map("profiles")
}

// ─── Device Tokens (Push Notifications) ──────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─── Household ────────────────────────────────────────────

model Household {
  id          String   @id @default(cuid())
  name        String
  familyMode  String   @default("co_parenting") @map("family_mode")
  caseNumber  String?  @map("case_number")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  members       HouseholdMember[]
  children      Child[]
  custodyPlans  CustodyPlan[]
  institutions  Institution[]

  @@map("households")
}

model HouseholdMember {
  id          String    @id @default(cuid())
  userId      String    @map("user_id") @db.Uuid
  householdId String    @map("household_id")
  role        String    @default("parent")
  joinedAt    DateTime  @default(now()) @map("joined_at") @db.Timestamptz

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@map("household_members")
}

// ─── Children ─────────────────────────────────────────────

model Child {
  id              String   @id @default(cuid())
  name            String
  birthDate       DateTime @map("birth_date") @db.Timestamptz
  avatar          String?
  parent1Id       String   @map("parent1_id") @db.Uuid
  parent2Id       String   @map("parent2_id") @db.Uuid
  householdId     String   @map("household_id")
  institutionName String?  @map("institution_name")
  institutionType String?  @map("institution_type")
  allergies       String[] @default([])
  medications     String[] @default([])
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  parent1       User          @relation("Parent1", fields: [parent1Id], references: [id])
  parent2       User          @relation("Parent2", fields: [parent2Id], references: [id])
  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  custodyPlans  CustodyPlan[]
  events        CalendarEvent[]
  milestones    Milestone[]
  photos        FamilyPhoto[]
  diaryEntries  DiaryEntry[]
  decisions     DecisionLog[]

  @@map("children")
}

// ─── Institution ──────────────────────────────────────────

model Institution {
  id            String   @id @default(cuid())
  name          String
  type          String
  address       String?
  phone         String?
  email         String?
  contactPerson String?  @map("contact_person")
  openingHours  String?  @map("opening_hours")
  householdId   String   @map("household_id")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("institutions")
}

// ─── Custody Plan ─────────────────────────────────────────

model CustodyPlan {
  id          String   @id @default(cuid())
  name        String
  pattern     String
  startDate   DateTime @map("start_date") @db.Timestamptz
  childId     String   @map("child_id")
  householdId String   @map("household_id")
  swapDay     Int      @default(4) @map("swap_day")
  swapTime    String   @default("18:00") @map("swap_time")
  parent1Days Int[]    @default([]) @map("parent1_days")
  parent2Days Int[]    @default([]) @map("parent2_days")

  weeklySchedule   Json? @map("weekly_schedule")
  customWeekConfig Json? @map("custom_week_config")
  customSchedule   Json? @map("custom_schedule")
  holidays         Json?
  specialDays      Json? @map("special_days")

  agreementDate       DateTime? @map("agreement_date") @db.Timestamptz
  agreementValidUntil DateTime? @map("agreement_valid_until") @db.Timestamptz
  agreementText       String?   @map("agreement_text")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("custody_plans")
}

// ─── Calendar Events ──────────────────────────────────────

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  startDate   DateTime @map("start_date") @db.Timestamptz
  endDate     DateTime @map("end_date") @db.Timestamptz
  type        String
  childId     String?  @map("child_id")
  createdBy   String   @map("created_by") @db.Uuid
  location    String?
  assignedTo  String[] @default([]) @map("assigned_to")
  isRecurring Boolean  @default(false) @map("is_recurring")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  child   Child? @relation(fields: [childId], references: [id])
  creator User   @relation(fields: [createdBy], references: [id])

  @@map("calendar_events")
}

// ─── Tasks ────────────────────────────────────────────────

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  assignedTo    String    @map("assigned_to") @db.Uuid
  createdBy     String    @map("created_by") @db.Uuid
  deadline      DateTime? @db.Timestamptz
  completed     Boolean   @default(false)
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  category      String    @default("general")
  isRecurring   Boolean   @default(false) @map("is_recurring")
  plannedWeekday Int?     @map("planned_weekday")
  area          String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  creator  User @relation("TaskCreator", fields: [createdBy], references: [id])
  assignee User @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@map("tasks")
}

// ─── Shopping Items ───────────────────────────────────────

model ShoppingItem {
  id           String    @id @default(cuid())
  name         String
  quantity     String?
  purchased    Boolean   @default(false)
  purchasedBy  String?   @map("purchased_by") @db.Uuid
  purchasedAt  DateTime? @map("purchased_at") @db.Timestamptz
  addedBy      String    @map("added_by") @db.Uuid
  category     String?
  priority     String    @default("normal")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("shopping_items")
}

// ─── Meal Plans ───────────────────────────────────────────

model MealPlan {
  id         String   @id @default(cuid())
  date       String
  mealType   String   @map("meal_type")
  title      String
  notes      String?
  createdBy  String   @map("created_by") @db.Uuid
  recipe     Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("meal_plans")
}

// ─── Messages / Communication ─────────────────────────────

model MessageThread {
  id           String    @id @default(cuid())
  title        String
  participants String[]
  childId      String?   @map("child_id")
  unreadCount  Int       @default(0) @map("unread_count")
  deletedBy    String[]  @default([]) @map("deleted_by")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  messages Message[]

  @@map("message_threads")
}

model Message {
  id          String    @id @default(cuid())
  content     String
  senderId    String    @map("sender_id") @db.Uuid
  threadId    String    @map("thread_id")
  readBy      String[]  @default([]) @map("read_by")
  deletedBy   String[]  @default([]) @map("deleted_by")
  attachments Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  sender User          @relation(fields: [senderId], references: [id])
  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Expenses ─────────────────────────────────────────────

model Expense {
  id            String    @id @default(cuid())
  title         String
  description   String?
  amount        Float
  currency      String    @default("DKK")
  category      String
  paidBy        String    @map("paid_by") @db.Uuid
  splitWith     String[]  @default([]) @map("split_with")
  splitAmounts  Json      @default("{}") @map("split_amounts")
  splitType     String    @default("equal") @map("split_type")
  date          DateTime  @db.Timestamptz
  status        String    @default("pending")
  receiptUrl    String?   @map("receipt_url")
  approvedBy    String[]  @default([]) @map("approved_by")
  isRecurring   Boolean   @default(false) @map("is_recurring")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  payer User @relation(fields: [paidBy], references: [id])

  @@map("expenses")
}

// ─── Documents ────────────────────────────────────────────

model Document {
  id           String   @id @default(cuid())
  title        String
  type         String
  url          String
  uploadedBy   String   @map("uploaded_by") @db.Uuid
  sharedWith   String[] @default([]) @map("shared_with")
  isOfficial   Boolean  @default(false) @map("is_official")
  validFrom    DateTime? @map("valid_from") @db.Timestamptz
  validUntil   DateTime? @map("valid_until") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  uploader User @relation(fields: [uploadedBy], references: [id])

  @@map("documents")
}

// ─── Milestones ───────────────────────────────────────────

model Milestone {
  id          String   @id @default(cuid())
  childId     String   @map("child_id")
  title       String
  description String?
  date        DateTime @db.Timestamptz
  category    String
  addedBy     String   @map("added_by") @db.Uuid
  photos      String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

// ─── Photos ───────────────────────────────────────────────

model FamilyPhoto {
  id       String   @id @default(cuid())
  childId  String   @map("child_id")
  url      String
  caption  String?
  takenAt  DateTime @map("taken_at") @db.Timestamptz
  addedBy  String   @map("added_by") @db.Uuid
  addedAt  DateTime @default(now()) @map("added_at") @db.Timestamptz

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [addedBy], references: [id])

  @@map("family_photos")
}

// ─── Diary ────────────────────────────────────────────────

model DiaryEntry {
  id        String   @id @default(cuid())
  childId   String   @map("child_id")
  date      DateTime @db.Timestamptz
  mood      String
  sleep     String
  appetite  String
  note      String?
  writtenBy String   @map("written_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [writtenBy], references: [id])

  @@map("diary_entries")
}

// ─── Decision Log ─────────────────────────────────────────

model DecisionLog {
  id          String    @id @default(cuid())
  childId     String?   @map("child_id")
  title       String
  description String
  category    String
  decidedAt   DateTime  @map("decided_at") @db.Timestamptz
  proposedBy  String    @map("proposed_by") @db.Uuid
  approvedBy  String[]  @default([]) @map("approved_by")
  status      String    @default("proposed")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  child    Child? @relation(fields: [childId], references: [id])
  proposer User   @relation("DecisionProposer", fields: [proposedBy], references: [id])

  @@map("decision_logs")
}

// ─── Meeting Minutes ──────────────────────────────────────

model MeetingMinutes {
  id          String   @id @default(cuid())
  title       String
  date        DateTime @db.Timestamptz
  location    String?
  agenda      String?
  decisions   Json?
  agreements  Json?
  nextSteps   Json?    @map("next_steps")
  writtenBy   String   @map("written_by") @db.Uuid
  approvedBy  String[] @default([]) @map("approved_by")
  status      String   @default("draft")
  isOfficial  Boolean  @default(false) @map("is_official")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("meeting_minutes")
}

// ─── Stripe Subscriptions ────────────────────────────────

model StripeSubscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id") @db.Uuid
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  plan                 String    @default("free")
  status               String    @default("inactive")
  billingInterval      String    @default("monthly") @map("billing_interval")
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stripe_subscriptions")
}

// ─── Key Dates ────────────────────────────────────────────

model KeyDate {
  id                String   @id @default(cuid())
  childId           String?  @map("child_id")
  title             String
  date              DateTime @db.Timestamptz
  type              String
  recurrence        String   @default("once")
  reminderDaysBefore Int     @default(7) @map("reminder_days_before")
  notes             String?
  addedBy           String   @map("added_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("key_dates")
}
